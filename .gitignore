# =============================================================================
# DGA Parallel Detection - .gitignore
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# --- Virtual Environment ---
venv/
env/
.venv/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Data (large files - download separately) ---
data/*.csv
data/*.pkl
data/english_dictionary.txt
!data/.gitkeep

# --- Results (regenerated by benchmarks) ---
results/metrics.json
results/plots/*.png
results/plots/*.pdf
!results/.gitkeep
!results/plots/.gitkeep

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Jupyter (if used for exploration) ---
.ipynb_checkpoints/
*.ipynb

# --- Logs ---
*.log
